# ── Stripe ──────────────────────────────────────────────────────────────────
# Required for real payments. Without this, checkout runs in mock/demo mode.
STRIPE_SECRET_KEY=sk_test_...

# Required to verify Stripe webhook signatures.
# Get this from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Required to send bundle-save confirmation emails.
# Get an API key at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── App URL ──────────────────────────────────────────────────────────────────
# Required in production. Used to generate bundle share links and checkout return URLs.
# In development this defaults to http://localhost:3002
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ── Google Analytics 4 ──────────────────────────────────────────────────────
# Optional. Add your GA4 Measurement ID to enable analytics.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
